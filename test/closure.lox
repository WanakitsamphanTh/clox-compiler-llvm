print("\n******************generating closures (single layered)******************");
fun greeting_generator(title, name){
    var _name = title + " " + name;
    fun greet(){
        return "Hello " + title + " " + name;
    }
    print "calling inside a function";
    print greet();
    return greet;
}

print "=========generating=========";
var a = greeting_generator("mr", "Pai");
var b = greeting_generator("mrs", "An");
print "=============================";
print a();
print b();

print("\n******************generating closure (multi-layered)******************");
fun f(x){
    fun g(y){
        fun h(msg){
            return msg + (x * y);
        }
        return h;
    }
    return g;
}

var g = f(5);
var h = g(10);
print h("x*y = ");  # expect 'x*y = 50'
                    # having problem with multilayer closure

print("\n****************** closure with get/set******************");
fun generator(x, y){
    fun decrement(){
        x = x - 1;
    }
    fun display(){
        print "in display(): " + x;
    }
    for(var i = 0; i < y; i = i + 1){
        decrement();
        print "after decrement: " + x;
    }
    return display;
}

var display = generator(5, 3);
display();


var increment;
var decrement;
fun generator_2(x,y){
    print "default x = " + x;
    fun inner_decrement(){
        x = x - y;
        print "after decrement by " + y + " = " + x;
    }
    decrement = inner_decrement;
    fun inner_increment(){
        x = x + y;
        print "after increment by " + y + " = " + x;
    }
    increment = inner_increment;
}

generator_2(5,1);

increment();
decrement();
increment();
increment();
decrement();