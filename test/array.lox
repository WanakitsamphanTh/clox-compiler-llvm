var x = {0,true,"abc",{1,2}};
print x;
for(var i = 0; i < len(x); i = i + 1){
    print "index " + i + " = " + x[i];
}

var y = 10;
var z = {y+1,y+2,y+3};
print z;

print "==========before==========";
for(var i = 0; i < len(z); i = i + 1){
    print "index " + i + " = " + z[i];
}

for(var i = 0; i < len(z); i = i + 1){
    z[i] = z[i] * 100;
}

print "==========after==========";
for(var i = 0; i < len(z); i = i + 1){
    print "index " + i + " = " + z[i];
}

print z[10];